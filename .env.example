# ============================================================
# 메타 광고 자동화 환경변수 템플릿
# ============================================================
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값으로 채워주세요
#   cp .env.example .env
# .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore 처리됨)
# ============================================================

# --- 메타 Marketing API ---
META_ACCESS_TOKEN=your_access_token_here
META_AD_ACCOUNT_ID=act_0000000000000000
META_PAGE_ID=0000000000000000
META_SYSTEM_USER_ID=0000000000000000
META_APP_ID=0000000000000000

# --- OpenAI (AI 이미지 생성) ---
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-...

# --- 기본값 ---
DEFAULT_LANDING_URL=https://nextvision.io.kr
# 생성 이미지 저장 경로 (없으면 자동 생성)
AD_IMAGE_DIR=./ad_images
